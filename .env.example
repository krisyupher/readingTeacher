# ======== API keys (set one or more) ========
# The server will try models in order, skipping any provider whose key is missing.

# Groq — fast, generous free tier. Get a key: https://console.groq.com/keys
GROQ_API_KEY=

# Google Gemini — free tier. Get a key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# OpenRouter — free access to Qwen, Llama, and others. Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OpenAI GPT — paid. Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ======== Chinese model providers (all OpenAI-compatible) ========

# DeepSeek — DeepSeek-V3 / R1. Get a key: https://platform.deepseek.com/api_keys
# Models: deepseek-chat (V3), deepseek-reasoner (R1)
DEEPSEEK_API_KEY=

# Qwen (Alibaba DashScope, international endpoint). Get a key: https://bailian.console.alibabacloud.com/
# Models: qwen-plus, qwen-turbo, qwen-max, qwen2.5-72b-instruct
QWEN_API_KEY=

# Zhipu AI / GLM. Get a key: https://open.bigmodel.cn/usercenter/apikeys
# Models: glm-4-flash (free), glm-4, glm-4-plus
ZHIPU_API_KEY=

# Baichuan. Get a key: https://platform.baichuan-ai.com/console/apikey
# Models: Baichuan4-Turbo, Baichuan3-Turbo
BAICHUAN_API_KEY=

# Yi (01.AI). Get a key: https://platform.lingyiwanwu.com/apikeys
# Models: yi-large, yi-medium, yi-spark, yi-lightning
YI_API_KEY=

# Moonshot AI / Kimi (international endpoint). Get a key: https://platform.moonshot.ai/console/api-keys
# Models: moonshot-v1-8k, moonshot-v1-32k, moonshot-v1-128k (long-context)
MOONSHOT_API_KEY=

# ======== Optional: custom model fallback chain ========
# Comma-separated list of "provider:model" entries tried in order.
# Unset = use the built-in default chain (Groq → Gemini → DeepSeek → Qwen → Zhipu → Moonshot → Yi → Baichuan → OpenRouter → OpenAI).
# LLM_MODELS=groq:llama-3.3-70b-versatile,deepseek:deepseek-chat,qwen:qwen-plus,zhipu:glm-4-flash,moonshot:moonshot-v1-8k,openai:gpt-4o-mini

PORT=3000

# Optional: restrict backend to your GitHub Pages origin when deploying split,
# e.g. https://<username>.github.io
ALLOWED_ORIGIN=
